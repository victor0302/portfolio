# /etc/blog/env — environment for blog.service.
#
# Owned by root:deploy, mode 0640. The deploy user reads via systemd's
# EnvironmentFile= directive but cannot modify /etc.
#
# Missing file is OK — the unit references this with
# EnvironmentFile=-/etc/blog/env so absence is allowed.

# Optional: enable AI-generated post summaries via Anthropic Claude.
# Get a key at https://console.anthropic.com — a small balance is
# enough for personal-blog scale (~$0.01 per summary on Haiku + caching).
#ANTHROPIC_API_KEY=sk-ant-...

# PORT and BLOG_DB are already set in the unit via Environment=.
# Only override here if you need to.
#PORT=8080
#BLOG_DB=/var/lib/blog/blog.sqlite
