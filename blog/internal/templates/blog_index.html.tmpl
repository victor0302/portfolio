{{define "content"}}
<section class="blog-index">
  <p class="prompt-row"><span class="g">vic@home</span>:<span class="b">~/blog</span>$ ls</p>
  <h1>Blog</h1>
  {{if .Posts}}
    <ul class="post-list">
      {{range .Posts}}
        <li class="post">
          <h2><a href="/blog/{{.Slug}}">{{.Title}}</a></h2>
          <p class="meta">
            <time datetime="{{.CreatedAt.Format "2006-01-02"}}">
              {{.CreatedAt.Format "Jan 2, 2006"}}
            </time>
          </p>
          <p class="excerpt">{{.Excerpt}}</p>
        </li>
      {{end}}
    </ul>
  {{else}}
    <p class="empty">No posts yet.</p>
  {{end}}
</section>
{{end}}
